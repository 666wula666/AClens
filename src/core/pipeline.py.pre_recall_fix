@contextmanager
def timer(name: str):
    start = time.time()
    yield
    end = time.time()
    logger.info(f"[{name}] took {end - start:.2f}s")

class VulnerabilityReport(BaseModel):
    contract_name: str
    function_name: str
    vulnerability_type: str
    root_cause: str
    severity: str
    remediation: str
    function_code: str = ""
    evidence: List[str] = []
    status: str = "OPEN"
    analysis_context: str = "" # Added to debug context issues

